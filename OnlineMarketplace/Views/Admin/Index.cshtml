@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold mb-0">
            <i class="bi bi-shield-lock text-danger"></i> Admin Dashboard
        </h3>
        <small class="text-muted">Manage your marketplace</small>
    </div>
</div>

<!-- Stats Cards -->
<div class="row g-4 mb-4">

    <div class="col-12 col-sm-4">
        <div class="card border-0 rounded-4 shadow-sm text-white h-100"
             style="background: linear-gradient(135deg, #3a77ff, #5b9bff);">
            <div class="card-body d-flex justify-content-between align-items-center p-4">
                <div>
                    <h2 class="fw-bold mb-0">@ViewBag.TotalUsers</h2>
                    <p class="mb-0 opacity-75">Total Users</p>
                </div>
                <i class="bi bi-people" style="font-size:2.5rem; opacity:0.6;"></i>
            </div>
            <div class="card-footer border-0 bg-transparent pb-3 pt-0">
                <a asp-action="Users" class="text-white text-decoration-none small">
                    View All Users <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="col-12 col-sm-4">
        <div class="card border-0 rounded-4 shadow-sm text-white h-100"
             style="background: linear-gradient(135deg, #28a745, #48c765);">
            <div class="card-body d-flex justify-content-between align-items-center p-4">
                <div>
                    <h2 class="fw-bold mb-0">@ViewBag.TotalProducts</h2>
                    <p class="mb-0 opacity-75">Total Products</p>
                </div>
                <i class="bi bi-box-seam" style="font-size:2.5rem; opacity:0.6;"></i>
            </div>
            <div class="card-footer border-0 bg-transparent pb-3 pt-0">
                <a asp-action="Products" class="text-white text-decoration-none small">
                    View All Products <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="col-12 col-sm-4">
        <div class="card border-0 rounded-4 shadow-sm text-white h-100"
             style="background: linear-gradient(135deg, #fd7e14, #ffa040);">
            <div class="card-body d-flex justify-content-between align-items-center p-4">
                <div>
                    <h2 class="fw-bold mb-0">@ViewBag.TotalCategories</h2>
                    <p class="mb-0 opacity-75">Categories</p>
                </div>
                <i class="bi bi-tags" style="font-size:2.5rem; opacity:0.6;"></i>
            </div>
        </div>
    </div>

</div>

<!-- Quick Links -->
<div class="row g-3">
    <div class="col-12 col-md-6">
        <div class="card border-0 rounded-4 shadow-sm p-3">
            <h6 class="fw-bold mb-3">
                <i class="bi bi-lightning text-warning"></i> Quick Actions
            </h6>
            <div class="d-grid gap-2">
                <a asp-action="Users" class="btn btn-outline-primary rounded-3">
                    <i class="bi bi-people"></i> Manage Users
                </a>
                <a asp-action="Products" class="btn btn-outline-success rounded-3">
                    <i class="bi bi-box-seam"></i> Manage Products
                </a>
                <a asp-controller="Home" asp-action="Index"
                       class="btn btn-outline-secondary rounded-3">
                    <i class="bi bi-house"></i> View Site
                </a>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-6">
        <div class="card border-0 rounded-4 shadow-sm p-3">
            <h6 class="fw-bold mb-3">
                <i class="bi bi-info-circle text-primary"></i> Site Summary
            </h6>
            <ul class="list-group list-group-flush">
                <li class="list-group-item d-flex justify-content-between px-0">
                    <span class="text-muted">Total Users</span>
                    <span class="fw-bold">@ViewBag.TotalUsers</span>
                </li>
                <li class="list-group-item d-flex justify-content-between px-0">
                    <span class="text-muted">Total Listings</span>
                    <span class="fw-bold">@ViewBag.TotalProducts</span>
                </li>
                <li class="list-group-item d-flex justify-content-between px-0">
                    <span class="text-muted">Categories</span>
                    <span class="fw-bold">@ViewBag.TotalCategories</span>
                </li>
            </ul>
        </div>
    </div>
</div>