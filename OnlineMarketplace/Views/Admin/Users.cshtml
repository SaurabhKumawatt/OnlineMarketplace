@model IEnumerable<OnlineMarketplace.Models.ApplicationUser>

@{
    ViewData["Title"] = "Manage Users";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold mb-0">
            <i class="bi bi-people text-primary"></i> All Users
        </h3>
        <small class="text-muted">@Model.Count() users registered</small>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary rounded-3">
        <i class="bi bi-arrow-left"></i> Dashboard
    </a>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-people text-muted" style="font-size:3rem;"></i>
        <h5 class="mt-3 text-muted">No users found</h5>
    </div>
}
else
{
    <!-- Desktop Table -->
    <div class="d-none d-md-block">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead style="background:#f8f9fa;">
                        <tr>
                            <th class="ps-4 py-3">Name</th>
                            <th class="py-3">Email</th>
                            <th class="py-3">Phone</th>
                            <th class="py-3 text-center">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            <tr>
                                <td class="ps-4 py-3">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="rounded-circle text-white d-flex
                                            align-items-center justify-content-center"
                                             style="width:36px; height:36px;
                                            background:#3a77ff; font-size:0.85rem;">
                                            @(user.FullName != null
                                                ? user.FullName.Substring(0, 1).ToUpper()
                                                : "U")
                                        </div>
                                        <span class="fw-semibold">@user.FullName</span>
                                    </div>
                                </td>
                                <td class="py-3">@user.Email</td>
                                <td class="py-3">
                                    @(user.PhoneNumber ?? "N/A")
                                </td>
                                <td class="py-3 text-center">
                                    <form asp-action="DeleteUser" method="post"
                                          onsubmit="return confirm('Delete this user?')">
                                        <input type="hidden" name="id" value="@user.Id" />
                                        <button type="submit"
                                                class="btn btn-sm btn-danger rounded-2">
                                            <i class="bi bi-trash"></i> Delete
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Mobile Cards -->
    <div class="d-md-none">
        @foreach (var user in Model)
        {
            <div class="card border-0 shadow-sm rounded-4 mb-3">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h6 class="fw-bold mb-1">@user.FullName</h6>
                            <small class="text-muted d-block">@user.Email</small>
                            <small class="text-muted">
                                <i class="bi bi-telephone"></i>
                                @(user.PhoneNumber ?? "N/A")
                            </small>
                        </div>
                        <form asp-action="DeleteUser" method="post"
                              onsubmit="return confirm('Delete this user?')">
                            <input type="hidden" name="id" value="@user.Id" />
                            <button type="submit" class="btn btn-sm btn-danger rounded-2">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}