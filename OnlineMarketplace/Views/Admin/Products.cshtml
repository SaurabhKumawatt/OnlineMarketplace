@model IEnumerable<OnlineMarketplace.Models.Product>

@{
    ViewData["Title"] = "Manage Products";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold mb-0">
            <i class="bi bi-box-seam text-success"></i> All Products
        </h3>
        <small class="text-muted">@Model.Count() listings total</small>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary rounded-3">
        <i class="bi bi-arrow-left"></i> Dashboard
    </a>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-inbox text-muted" style="font-size:3rem;"></i>
        <h5 class="mt-3 text-muted">No products found</h5>
    </div>
}
else
{
    <!-- Desktop Table -->
    <div class="d-none d-md-block">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead style="background:#f8f9fa;">
                        <tr>
                            <th class="ps-4 py-3">Image</th>
                            <th class="py-3">Title</th>
                            <th class="py-3">Price</th>
                            <th class="py-3">City</th>
                            <th class="py-3">Category</th>
                            <th class="py-3">Date</th>
                            <th class="py-3 text-center">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 py-3">
                                    @if (!string.IsNullOrEmpty(item.ImagePath))
                                    {
                                        <img src="@item.ImagePath"
                                             class="rounded-2"
                                             style="width:55px; height:55px;
                                        object-fit:cover;" />
                                    }
                                    else
                                    {
                                        <div class="bg-light rounded-2 d-flex
                                            align-items-center justify-content-center"
                                             style="width:55px; height:55px;">
                                            <i class="bi bi-image text-muted"></i>
                                        </div>
                                    }
                                </td>
                                <td class="py-3 fw-semibold">@item.Title</td>
                                <td class="py-3 text-success fw-bold">₹@item.Price</td>
                                <td class="py-3">@item.City</td>
                                <td class="py-3">
                                    <span class="badge rounded-pill"
                                          style="background:#e8f0ff; color:#3a77ff;">
                                        @(item.Category != null ? item.Category.Name : "N/A")
                                    </span>
                                </td>
                                <td class="py-3 text-muted small">
                                    @item.CreatedDate.ToShortDateString()
                                </td>
                                <td class="py-3 text-center">
                                    <form asp-action="DeleteProduct" method="post"
                                          onsubmit="return confirm('Delete this product?')">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit"
                                                class="btn btn-sm btn-danger rounded-2">
                                            <i class="bi bi-trash"></i> Delete
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Mobile Cards -->
    <div class="d-md-none">
        @foreach (var item in Model)
        {
            <div class="card border-0 shadow-sm rounded-4 mb-3">
                <div class="card-body">
                    <div class="d-flex gap-3">

                        @if (!string.IsNullOrEmpty(item.ImagePath))
                        {
                            <img src="@item.ImagePath" class="rounded-3"
                                 style="width:70px; height:70px; object-fit:cover;" />
                        }

                        <div class="flex-fill">
                            <h6 class="fw-bold mb-1">@item.Title</h6>
                            <p class="text-success fw-bold mb-1 small">₹@item.Price</p>
                            <small class="text-muted">
                                <i class="bi bi-geo-alt"></i> @item.City
                            </small>
                        </div>

                        <form asp-action="DeleteProduct" method="post"
                              onsubmit="return confirm('Delete this product?')">
                            <input type="hidden" name="id" value="@item.Id" />
                            <button type="submit" class="btn btn-sm btn-danger rounded-2">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>

                    </div>
                </div>
            </div>
        }
    </div>
}