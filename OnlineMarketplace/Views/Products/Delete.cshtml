@model OnlineMarketplace.Models.Product

@{
    ViewData["Title"] = "Delete Ad";
}

<div class="row justify-content-center mt-4">
    <div class="col-12 col-md-6 col-lg-5">

        <div class="card border-0 shadow rounded-4">
            <div class="card-body p-4 text-center">

                <i class="bi bi-exclamation-triangle-fill text-danger"
                   style="font-size:3rem;"></i>
                <h3 class="fw-bold mt-3">Delete Ad?</h3>
                <p class="text-muted">This action cannot be undone.</p>

                <hr />

                @if (!string.IsNullOrEmpty(Model.ImagePath))
                {
                    <img src="@Model.ImagePath" class="rounded-3 mb-3"
                         style="width:100%; height:180px; object-fit:cover;" />
                }

                <div class="text-start mb-3">
                    <p class="mb-1">
                        <strong>Title:</strong> @Model.Title
                    </p>
                    <p class="mb-1">
                        <strong>Price:</strong>
                        <span class="text-success">₹@Model.Price</span>
                    </p>
                    <p class="mb-1">
                        <strong>City:</strong> @Model.City
                    </p>
                    <p class="mb-0">
                        <strong>Posted:</strong>
                        @Model.CreatedDate.ToShortDateString()
                    </p>
                </div>

                <hr />

                <form asp-action="Delete" class="d-grid gap-2">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger btn-lg rounded-3 fw-bold">
                        <i class="bi bi-trash"></i> Yes, Delete
                    </button>
                    <a asp-action="MyProducts"
                           class="btn btn-outline-secondary rounded-3">
                        <i class="bi bi-x-circle"></i> Cancel
                    </a>
                </form>

            </div>
        </div>

    </div>
</div>