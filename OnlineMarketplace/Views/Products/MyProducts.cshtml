@model IEnumerable<OnlineMarketplace.Models.Product>

@{
    ViewData["Title"] = "My Listings";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold mb-0">
            <i class="bi bi-collection"></i> My Listings
        </h3>
        <small class="text-muted">Manage your posted ads</small>
    </div>
    <a asp-action="Create" class="btn btn-primary rounded-3">
        <i class="bi bi-plus-lg"></i> Post New Ad
    </a>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-inbox text-muted" style="font-size:3rem;"></i>
        <h5 class="mt-3 text-muted">You have no listings yet</h5>
        <p class="text-muted small">Start selling by posting your first ad</p>
        <a asp-action="Create" class="btn btn-primary rounded-3 mt-2">
            <i class="bi bi-plus-lg"></i> Post First Ad
        </a>
    </div>
}
else
{
    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-12 col-sm-6 col-lg-4 mb-4">
                <div class="card h-100 shadow-sm border-0 rounded-4">

                    @if (!string.IsNullOrEmpty(item.ImagePath))
                    {
                        <img src="@item.ImagePath" class="card-img-top"
                             style="height:180px; object-fit:cover;
                        border-radius:12px 12px 0 0;" />
                    }
                    else
                    {
                        <div class="bg-light text-center rounded-top"
                             style="height:180px; line-height:180px;">
                            <i class="bi bi-image text-muted"
                               style="font-size:2.5rem;"></i>
                        </div>
                    }

                    <div class="card-body pb-1">
                        <h6 class="fw-bold mb-1"
                            style="white-space:nowrap; overflow:hidden;
                            text-overflow:ellipsis;">
                            @item.Title
                        </h6>
                        <p class="text-success fw-bold mb-1 fs-6">₹@item.Price</p>
                        <small class="text-muted">
                            <i class="bi bi-geo-alt"></i> @item.City
                            &nbsp;|&nbsp;
                            <i class="bi bi-tag"></i>
                            @(item.Category != null ? item.Category.Name : "N/A")
                        </small>
                    </div>

                    <div class="card-footer d-flex justify-content-between
                        align-items-center border-0 bg-white rounded-bottom p-3">
                        <small class="text-muted">
                            <i class="bi bi-clock"></i>
                            @item.CreatedDate.ToShortDateString()
                        </small>
                        <div class="d-flex gap-2">
                            <a asp-action="Details" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-primary rounded-2">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a asp-action="Edit" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-warning rounded-2">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-danger rounded-2">
                                <i class="bi bi-trash"></i>
                            </a>
                        </div>
                    </div>

                </div>
            </div>
        }
    </div>
}