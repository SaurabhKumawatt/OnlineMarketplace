@model OnlineMarketplace.Models.Product

@{
    ViewData["Title"] = "Product Details";
}

<div class="row mt-3 g-4">

    <!-- Product Image -->
    <div class="col-12 col-md-6">
        @if (!string.IsNullOrEmpty(Model.ImagePath))
        {
            <img src="@Model.ImagePath" class="img-fluid rounded-4 shadow"
                 style="width:100%; height:400px; object-fit:cover;" />
        }
        else
        {
            <div class="bg-light text-center rounded-4 py-5 shadow-sm"
                 style="height:400px; line-height:380px;">
                <i class="bi bi-image text-muted" style="font-size:4rem;"></i>
            </div>
        }
    </div>

    <!-- Product Info -->
    <div class="col-12 col-md-6">

        <div class="card border-0 shadow-sm rounded-4 p-4 h-100">

            <span class="badge mb-2"
                  style="background:#e8f0ff; color:#3a77ff; width:fit-content;">
                <i class="bi bi-tag"></i>
                @(Model.Category != null ? Model.Category.Name : "N/A")
            </span>

            <h2 class="fw-bold">@Model.Title</h2>
            <h3 class="text-success fw-bold">₹@Model.Price</h3>

            <hr />

            <p class="text-muted">
                <i class="bi bi-geo-alt text-primary"></i>
                <strong>City:</strong> @Model.City
            </p>

            <p>
                <i class="bi bi-text-left text-primary"></i>
                <strong>Description:</strong><br />
                <span class="text-muted">@Model.Description</span>
            </p>

            <p class="text-muted small">
                <i class="bi bi-clock"></i>
                Posted on @Model.CreatedDate.ToShortDateString()
            </p>

            <hr />

            <!-- Contact Seller Box -->
            <div class="card rounded-4 border-0"
                 style="background:#f0fff4;">
                <div class="card-body">
                    <h6 class="fw-bold text-success mb-3">
                        <i class="bi bi-person-circle"></i> Contact Seller
                    </h6>

                    <p class="mb-2">
                        <i class="bi bi-person text-success"></i>
                        <strong>Name:</strong> @ViewBag.SellerName
                    </p>

                    <p class="mb-2">
                        <i class="bi bi-telephone text-success"></i>
                        <strong>Phone:</strong>
                        <a href="tel:@ViewBag.SellerPhone"
                               class="text-success fw-bold text-decoration-none">
                            @ViewBag.SellerPhone
                        </a>
                    </p>

                    <p class="mb-0">
                        <i class="bi bi-envelope text-success"></i>
                        <strong>Email:</strong>
                        <a href="mailto:@ViewBag.SellerEmail"
                               class="text-success text-decoration-none">
                            @ViewBag.SellerEmail
                        </a>
                    </p>
                </div>
            </div>

            <div class="mt-3 d-flex gap-2">
                <a href="tel:@ViewBag.SellerPhone"
                       class="btn btn-success flex-fill rounded-3">
                    <i class="bi bi-telephone"></i> Call Seller
                </a>
                <a asp-controller="Home" asp-action="Index"
                       class="btn btn-outline-secondary flex-fill rounded-3">
                    <i class="bi bi-arrow-left"></i> Back
                </a>
            </div>

        </div>
    </div>
</div>