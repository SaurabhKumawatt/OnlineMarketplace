@model IEnumerable<OnlineMarketplace.Models.Product>

@{
    ViewData["Title"] = "Home";
}

<!-- Hero Section -->
<div class="rounded-3 p-4 p-md-5 mb-4 text-white"
     style="background: linear-gradient(135deg, #3a77ff, #00c6ff);">
    <div class="text-center">
        <h1 class="fw-bold">Buy & Sell Anything</h1>
        <p class="lead">Find great deals near you</p>
    </div>

    <!-- Search Form -->
    <form asp-controller="Home" asp-action="Index" method="get">
        <div class="row g-2 justify-content-center mt-2">
            <div class="col-12 col-md-4">
                <input type="text" name="search" value="@ViewBag.Search"
                       class="form-control form-control-lg"
                       placeholder="Search products..." />
            </div>
            <div class="col-12 col-md-3">
                <select name="categoryId" class="form-control form-control-lg">
                    <option value="">All Categories</option>
                    @foreach (var cat in ViewBag.Categories)
                    {
                        if (ViewBag.SelectedCategory == cat.Id)
                        {
                            <option value="@cat.Id" selected>@cat.Name</option>
                        }
                        else
                        {
                            <option value="@cat.Id">@cat.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="col-12 col-md-2">
                <input type="text" name="city" value="@ViewBag.City"
                       class="form-control form-control-lg"
                       placeholder="City..." />
            </div>
            <div class="col-6 col-md-1">
                <button type="submit" class="btn btn-light btn-lg w-100 fw-bold">
                    <i class="bi bi-search"></i>
                </button>
            </div>
            <div class="col-6 col-md-1">
                <a asp-controller="Home" asp-action="Index"
                       class="btn btn-outline-light btn-lg w-100">
                    <i class="bi bi-x-lg"></i>
                </a>
            </div>
        </div>
    </form>
</div>

<!-- Results -->
<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0">
        <i class="bi bi-grid"></i> @Model.Count() listings found
    </h5>
    <a asp-controller="Products" asp-action="Create" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg"></i> Post Free Ad
    </a>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-search" style="font-size:3rem; color:#ccc;"></i>
        <h4 class="mt-3 text-muted">No products found</h4>
        <a asp-controller="Products" asp-action="Create" class="btn btn-primary mt-2">
            Post First Ad
        </a>
    </div>
}
else
{
    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-6 col-md-4 col-lg-3 mb-4">
                <div class="card h-100 shadow-sm">
                    <a asp-controller="Products" asp-action="Details"
                           asp-route-id="@item.Id" class="text-decoration-none">

                        @if (!string.IsNullOrEmpty(item.ImagePath))
                        {
                            <img src="@item.ImagePath" class="card-img-top"
                                 style="height:160px; object-fit:cover;" />
                        }
                        else
                        {
                            <div class="bg-light text-center py-4"
                                 style="height:160px; line-height:120px;">
                                <i class="bi bi-image text-muted" style="font-size:2rem;"></i>
                            </div>
                        }

                        <div class="card-body p-2">
                            <p class="text-success fw-bold mb-1 fs-6">₹@item.Price</p>
                            <h6 class="card-title text-dark mb-1"
                                style="font-size:0.9rem; white-space:nowrap;
                                overflow:hidden; text-overflow:ellipsis;">
                                @item.Title
                            </h6>
                            <small class="text-muted">
                                <i class="bi bi-geo-alt"></i> @item.City &nbsp;
                                <i class="bi bi-tag"></i>
                                @(item.Category != null ? item.Category.Name : "N/A")
                            </small>
                        </div>

                    </a>
                    <div class="card-footer p-2 text-muted"
                         style="font-size:0.75rem;">
                        <i class="bi bi-clock"></i>
                        @item.CreatedDate.ToShortDateString()
                    </div>
                </div>
            </div>
        }
    </div>
}