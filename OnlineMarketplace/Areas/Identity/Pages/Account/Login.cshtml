@page
@model LoginModel
@{
    ViewData["Title"] = "Login";
}

<div class="row justify-content-center mt-4">
    <div class="col-12 col-md-5 col-lg-4">

        <div class="card shadow border-0 rounded-4">
            <div class="card-body p-4">

                <div class="text-center mb-4">
                    <h2 class="fw-bold" style="color:#3a77ff;">🛒 MarketPlace</h2>
                    <p class="text-muted">Login to your account</p>
                </div>

                <form id="account" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"
                         role="alert"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.Email" class="form-control"
                               autocomplete="username" placeholder="name@example.com" />
                        <label asp-for="Input.Email">
                            <i class="bi bi-envelope"></i> Email
                        </label>
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.Password" class="form-control"
                               autocomplete="current-password" placeholder="Password" />
                        <label asp-for="Input.Password">
                            <i class="bi bi-lock"></i> Password
                        </label>
                        <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div class="form-check">
                            <input asp-for="Input.RememberMe" class="form-check-input" />
                            <label asp-for="Input.RememberMe" class="form-check-label small">
                                Remember me
                            </label>
                        </div>
                        <a asp-page="./ForgotPassword" class="small text-primary">
                            Forgot password?
                        </a>
                    </div>

                    <button type="submit" class="btn w-100 fw-bold py-2 rounded-3"
                            style="background:#3a77ff; color:white;">
                        <i class="bi bi-box-arrow-in-right"></i> Login
                    </button>

                    <hr class="my-3" />

                    <div class="text-center">
                        <p class="mb-0 small text-muted">Don't have an account?</p>
                        <a asp-page="./Register" class="btn btn-outline-primary w-100 mt-2">
                            Create Account
                        </a>
                    </div>

                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}