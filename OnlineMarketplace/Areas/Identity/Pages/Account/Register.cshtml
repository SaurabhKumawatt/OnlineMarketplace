@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="row justify-content-center mt-4">
    <div class="col-12 col-md-6 col-lg-5">

        <div class="card shadow border-0 rounded-4">
            <div class="card-body p-4">

                <div class="text-center mb-4">
                    <h2 class="fw-bold" style="color:#3a77ff;">🛒 MarketPlace</h2>
                    <p class="text-muted">Create your free account</p>
                </div>

                <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"
                         role="alert"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.FullName" class="form-control"
                               placeholder="Full Name" />
                        <label asp-for="Input.FullName">
                            <i class="bi bi-person"></i> Full Name
                        </label>
                        <span asp-validation-for="Input.FullName" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.PhoneNumber" class="form-control"
                               placeholder="Phone Number" />
                        <label asp-for="Input.PhoneNumber">
                            <i class="bi bi-telephone"></i> Phone Number
                        </label>
                        <span asp-validation-for="Input.PhoneNumber"
                              class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.Email" class="form-control"
                               autocomplete="username" placeholder="name@example.com" />
                        <label asp-for="Input.Email">
                            <i class="bi bi-envelope"></i> Email
                        </label>
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.Password" class="form-control"
                               autocomplete="new-password" placeholder="Password" />
                        <label asp-for="Input.Password">
                            <i class="bi bi-lock"></i> Password
                        </label>
                        <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.ConfirmPassword" class="form-control"
                               autocomplete="new-password" placeholder="Confirm Password" />
                        <label asp-for="Input.ConfirmPassword">
                            <i class="bi bi-lock-fill"></i> Confirm Password
                        </label>
                        <span asp-validation-for="Input.ConfirmPassword"
                              class="text-danger small"></span>
                    </div>

                    <button id="registerSubmit" type="submit"
                            class="btn w-100 fw-bold py-2 rounded-3"
                            style="background:#3a77ff; color:white;">
                        <i class="bi bi-person-plus"></i> Create Account
                    </button>

                    <hr class="my-3" />

                    <div class="text-center">
                        <p class="mb-0 small text-muted">Already have an account?</p>
                        <a asp-page="./Login" class="btn btn-outline-primary w-100 mt-2">
                            Login
                        </a>
                    </div>

                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}